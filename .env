# CONFIGURAÇÃO DO SISTEMA DE RASTREAMENTO DE TRANSPORTADORA
# Copie este arquivo para .env e preencha com suas configurações

# ============= CONFIGURAÇÃO DE API =============
# URL base da API da transportadora
# Exemplo: https://www.siterastreio.com.br/api-correios
API_BASE_URL=https://api-labs.wonca.com.br

# Timeout para requisições HTTP (segundos)
API_TIMEOUT=30

# Número de tentativas em caso de falha
API_RETRIES=3

# Chave de API (deixe em branco se não necessário)
API_KEY=4dm6lbd0kXJvKY5RncHvZQ3M6Gx3us4xrSPjgayCwn4s

# ============= RATE LIMITING =============
# Número máximo de requisições permitidas
RATE_LIMIT_REQUESTS=100

# Período em segundos para contar as requisições
RATE_LIMIT_PERIOD=60

# ============= CONFIGURAÇÃO DE ARQUIVOS =============
# Caminho da planilha Excel com dados de rastreamento
EXCEL_FILE_PATH=planilha_rastreamento.xlsx

# Pasta onde backups serão armazenados
BACKUP_FOLDER=backups

# Pasta onde logs serão armazenados
LOG_FOLDER=logs

# ============= COLUNAS DE EXCEL =============
# Configure os nomes das colunas conforme sua planilha
COLUNA_NF=NF
COLUNA_RASTREAMENTO=Rastreamento
COLUNA_STATUS=Status
COLUNA_ULTIMA_ATUALIZACAO=Última Atualização
COLUNA_DETALHES=Detalhes

# ============= CONFIGURAÇÃO DE LOGGING =============
# Nível de log: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ============= PROCESSAMENTO =============
# Atualizar apenas registros com mudança de status
ATUALIZAR_APENAS_MUDANCAS=True

# Criar backup antes de processar
CRIAR_BACKUP_ANTES=True

# Salvar relatório em arquivo após processamento
SALVAR_RELATORIO=True
