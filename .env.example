COLUNA_ULTIMA_ATUALIZACAO=Última Atualização
COLUNA_DETALHES=Detalhes

# ============= CONFIGURAÇÃO DE LOGGING =============
LOG_LEVEL=INFO

# ============= PROCESSAMENTO =============
ATUALIZAR_APENAS_MUDANCAS=True
CRIAR_BACKUP_ANTES=True
SALVAR_RELATORIO=True
